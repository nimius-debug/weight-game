# Postgres connection string (Neon free tier recommended).
# Local dev example: postgres://postgres:postgres@localhost:5432/weightgame
DATABASE_URL="postgres://user:password@host/dbname"

# Shared secret that gates the /admin page. Pick something long & random.
ADMIN_TOKEN="change-me-to-a-long-random-string"

# Public base URL, used when generating participants' personal links.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Vercel Blob — required for scale photo uploads.
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Anthropic API key — enables AI scale-photo verification (optional).
# If unset, photos are accepted without verification.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# --- Added in milestone 4 (SMS hybrid via Twilio) ---
# TWILIO_AUTH_TOKEN=""
